# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Sheets (portfolio data source)
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# App URL (used in emails and push notifications)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Resend (email notifications) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Web Push / VAPID — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your@email.com

# Cron job secret (set in cron-job.org and Vercel)
CRON_SECRET=your_random_secret_string

# Env admin account (fallback: Jack Schlosser)
ADMIN_NAME=Jack Schlosser
ADMIN_EMAIL=jack@dormdao.io
ADMIN_EMAILS=carsen@dormdao.io
ADMIN_WALLET=0xYourWalletAddress
ADMIN_VOTING_UNITS=10

# Vercel (auto-set in deployed environments)
VERCEL_URL=your-project.vercel.app

# Legacy admin secret for UI gating (not a real secret — visible in client bundle)
NEXT_PUBLIC_ADMIN_SECRET=your_admin_secret
